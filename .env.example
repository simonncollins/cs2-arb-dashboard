# CS2 Arbitrage Dashboard — Environment Variables
# Copy this file to .env and fill in real values

# --- OddsAPI ---
ODDS_API_KEY=your_odds_api_key_here

# --- Polymarket CLOB ---
# No key required for public read-only endpoints, but set host if needed:
POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# --- App settings ---
# Minimum arbitrage profit threshold (as decimal, e.g. 0.02 = 2%)
ARB_MIN_PROFIT_THRESHOLD=0.01

# Cache TTL in seconds for API responses
CACHE_TTL_SECONDS=60

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
