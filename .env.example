# OddsAPI key (free tier from the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# Polymarket — no auth required

# Alert configuration (optional — leave empty to disable)
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# Refresh interval in seconds (default: 60)
REFRESH_INTERVAL_SECONDS=60

# Minimum arbitrage edge % to show/alert (default: 2.0)
MIN_ARBITRAGE_EDGE_PCT=2.0
